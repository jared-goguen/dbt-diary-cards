# DBT Diary Card Template
# Dynamic, editable template for daily diary entries

template:
  name: diary
  route: /diary/[date]
  routeParam: date
  storage: r2

page:
  meta:
    title: "Diary Card — {{DATE}}"
    description: "Daily DBT diary entry for {{DATE}}"
    author: "T001"
  
  sections:
    # Hero section - EDITABLE (can change heading text)
    - type: hero
      _editable: true
      content:
        heading: "Daily Diary Card — {{DATE}}"
    
    # TABLE 1: BOOKKEEPING (Daily functioning) - EDITABLE
    - type: table
      _editable: true
      label: BOOKKEEPING
      cells:
        - label: Sleep
          value: ""
          type: text
        - label: Meds
          value: false
          type: bool
        - label: Self
          value: 0
          type: numeric
          color-scale: [0, 10]
        - label: Partner
          value: 0
          type: numeric
          color-scale: [0, 10]
        - label: Work
          value: 0
          type: numeric
          color-scale: [0, 10]
        - label: Social
          value: 0
          type: numeric
          color-scale: [0, 10]
    
    # TABLE 2: EMOTIONS - EDITABLE
    - type: table
      _editable: true
      label: EMOTIONS
      cells:
        - label: SAD
          value: 0
          type: numeric
          color-scale: [0, 10]
        - label: ANG
          value: 0
          type: numeric
          color-scale: [0, 10]
        - label: ANX
          value: 0
          type: numeric
          color-scale: [0, 10]
        - label: SHA
          value: 0
          type: numeric
          color-scale: [0, 10]
        - label: LONE
          value: 0
          type: numeric
          color-scale: [0, 10]
        - label: HOPE
          value: 0
          type: numeric
          color-scale: [0, 10]
    
    # TABLE 3: URGES/SKILLS - EDITABLE
    - type: table
      _editable: true
      label: URGES/SKILLS
      cells:
        - label: URG
          value: 0
          type: numeric
          color-scale: [0, 10]
        - label: SUB
          value: 0
          type: numeric
          color-scale: [0, 10]
        - label: MIND
          value: false
          type: bool
        - label: REG
          value: false
          type: bool
        - label: DIST
          value: false
          type: bool
        - label: SELF
          value: false
          type: bool
    
    # Daily Notes - EDITABLE
    - type: content
      _editable: true
      variant: prose
      markdown: |
        ## Daily Notes
        
        **Triggers:** 
        
        **Skills:** 
        
        **Therapist Focus:**
